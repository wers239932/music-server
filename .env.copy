# =============================================================================
# Music Stack — Переменные окружения
# =============================================================================
# Скопируйте этот файл в .env и заполните реальные значения:
#   cp .env.copy .env
# =============================================================================

# ---------------------------------------------------------------------------
# Last.fm API (нужен для скробблинга и рекомендаций)
# Получить ключи: https://www.last.fm/api/account/create
# ---------------------------------------------------------------------------
LASTFM_API_KEY=вставьте_ваш_lastfm_api_key
LASTFM_SECRET=вставьте_ваш_lastfm_secret

# ---------------------------------------------------------------------------
# Lidarr API-ключ
# Сгенерируется автоматически при первом запуске Lidarr.
# Откройте http://<ваш-ip>:8686 → Settings → General → скопируйте API Key.
# После вставки выполните: docker compose restart lidarr-youtube-downloader
# ---------------------------------------------------------------------------
LIDARR_API_KEY=вставьте_ключ_из_настроек_lidarr

# ---------------------------------------------------------------------------
# Часовой пояс (используется Lidarr и другими сервисами)
# Список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# ---------------------------------------------------------------------------
TZ=Europe/Moscow